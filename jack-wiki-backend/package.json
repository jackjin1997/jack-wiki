{
  "name": "jack-wiki-backend",
  "version": "0.1.0",
  "description": "Jack Wiki 个人知识库后端 - Clean Architecture + Elysia + tRPC",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "db:init": "tsx src/infrastructure/database/init.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx src/infrastructure/database/init.ts && drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/infrastructure/database/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "cxp": "workspace:*",
    "@aws-sdk/client-s3": "^3.651.1",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/trpc": "^1.1.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.1.0",
    "@langchain/openai": "^0.3.0",
    "@trpc/server": "^11.8.1",
    "@upstash/redis": "^1.34.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "elysia": "^1.1.0",
    "langchain": "^0.3.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
