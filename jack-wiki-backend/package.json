{
  "name": "jack-wiki-backend",
  "version": "0.1.0",
  "description": "Jack Wiki 个人知识库后端 - Clean Architecture + Elysia + tRPC",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/infrastructure/database/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "elysia": "^1.1.0",
    "@elysiajs/trpc": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.1.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "@upstash/redis": "^1.34.0",
    "@aws-sdk/client-s3": "^3.651.1",
    "langchain": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "drizzle-kit": "^0.26.0",
    "typescript": "^5.6.0",
    "eslint": "^9.11.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "prettier": "^3.3.3",
    "bun-types": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  }
}
